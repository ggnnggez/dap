# Copy to .env and fill in. .env is gitignored.
#
# Pick ONE provider, set DAP_MODEL accordingly, and fill in the matching key.
# All model strings use LiteLLM's "provider/model" form.

DAP_MODEL=anthropic/claude-sonnet-4-6

# ---------- Anthropic ----------
# Examples: anthropic/claude-sonnet-4-6, anthropic/claude-opus-4-7
ANTHROPIC_API_KEY=

# ---------- OpenAI ----------
# Examples: openai/gpt-4o, openai/gpt-4o-mini, openai/o1
OPENAI_API_KEY=

# ---------- Moonshot / Kimi ----------
# LiteLLM defaults to the international endpoint (api.moonshot.ai). For the
# China region (platform.moonshot.cn), set MOONSHOT_API_BASE explicitly.
# The two regions use SEPARATE API keys — they are not interchangeable.
# Examples: moonshot/moonshot-v1-128k, moonshot/kimi-k2
MOONSHOT_API_KEY=
MOONSHOT_API_BASE=https://api.moonshot.cn/v1

# ---------- Google Gemini  (https://aistudio.google.com) ----------
# Examples: gemini/gemini-2.5-pro, gemini/gemini-2.5-flash, gemini/gemini-2.0-flash
GEMINI_API_KEY=

# ---------- OpenRouter  (https://openrouter.ai) ----------
# Format is openrouter/<provider>/<model>. Examples:
#   openrouter/anthropic/claude-sonnet-4-5
#   openrouter/google/gemini-2.5-pro
#   openrouter/meta-llama/llama-3.3-70b-instruct
OPENROUTER_API_KEY=

# ---------- DeepSeek  (https://platform.deepseek.com) ----------
# Examples: deepseek/deepseek-chat, deepseek/deepseek-reasoner
DEEPSEEK_API_KEY=
